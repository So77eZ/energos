# Нормализация переводов строк: в репозитории всегда LF (убирает CRLF-ворнинги
# на Windows при каждом `git add`). Текст определяется автоматически.
* text=auto eol=lf

# Бинарные — не трогать.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.svg   text
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.zip   binary
*.pdf   binary
